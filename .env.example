# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Prisma) ────────────────────────────────────────────────────────
# DATABASE_URL → Transaction pooler (port 6543) — used by Vercel serverless functions
# Get from: Supabase Dashboard > Project Settings > Database > Connection string > Transaction
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL → Direct connection (port 5432) — used for prisma migrate / prisma db push
# Get from: Supabase Dashboard > Project Settings > Database > Connection string > Direct
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-key-here

# ─── Admin panel ──────────────────────────────────────────────────────────────
# REQUIRED in production. There is NO hardcoded fallback — if ADMIN_PASSWORD is
# unset, the built-in owner login is disabled (use a DB admin_users row instead).
ADMIN_EMAIL=you@example.com
# Generate a strong one: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PASSWORD=set-a-strong-unique-password
# Optional: dedicated secret for signing admin session tokens. If omitted, a key
# is derived from ENCRYPTION_KEY (with domain separation). Set this to rotate /
# invalidate all admin sessions independently of ENCRYPTION_KEY.
ADMIN_TOKEN_SECRET=
# Protects Vercel cron endpoints. Vercel sends "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=set-a-long-random-string

# ─── Razorpay ────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys (use live keys in production)
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Set in Razorpay Dashboard > Settings > Webhooks > Secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# Create plans: Razorpay Dashboard > Products > Subscriptions > Plans
# Current model: one $50/mo plan (400 credits). Legacy tier ids below are unused.
RAZORPAY_FLOWFIY_PLAN_ID=plan_...
RAZORPAY_INDIE_PLAN_ID=plan_...
RAZORPAY_STARTER_PLAN_ID=plan_...
RAZORPAY_GROWTH_PLAN_ID=plan_...
RAZORPAY_AGENCY_PLAN_ID=plan_...

# ─── Google OAuth (for Gmail integration) ────────────────────────────────────
# Create at: https://console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0 Client
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Development:
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback
# Production:
GOOGLE_REDIRECT_URI=https://flowfiy.com/api/integrations/gmail/callback

# ─── Google Gemini (managed AI — primary) ─────────────────────────────────────
# Powers the planner + research/qualify/personalize pipeline (web + worker).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional model overrides (defaults live in src/ai/config.ts):
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_FLASH_LITE_MODEL=gemini-2.5-flash-lite
# Optional — only when using Vertex AI instead of AI Studio:
# GEMINI_PROJECT=your-gcp-project-id
# GEMINI_PROJECT_NUMBER=1234567890

# ─── Apify + Prospeo (managed lead data — Flowfiy-owned) ──────────────────────
# Platform Apify token runs the Google Maps + B2B people-finder actors for ALL
# orgs (worker). Get from: https://console.apify.com/account/integrations
APIFY_PLATFORM_TOKEN=apify_api_...
# Prospeo resolves B2B emails when the actor lacks one (worker). https://prospeo.io
PROSPEO_API_KEY=your-prospeo-key

# ─── Anthropic (optional fallback seam only — Gemini is primary) ──────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Stripe (international payments — Razorpay handles IN) ────────────────────
# Leave UNSET to route all traffic through Razorpay. Set these to enable Stripe
# for non-India users — create one Price per plan in the Stripe dashboard.
STRIPE_SECRET_KEY=sk_live_...
# Stripe webhook signing secret — Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FLOWFIY_PRICE_ID=price_...   # the $50/mo plan
STRIPE_INDIE_PRICE_ID=price_...     # legacy
STRIPE_STARTER_PRICE_ID=price_...   # legacy
STRIPE_GROWTH_PRICE_ID=price_...    # legacy
STRIPE_AGENCY_PRICE_ID=price_...    # legacy

# ─── Redis (BullMQ queue + rate limiting) ─────────────────────────────────────
# REDIS_URL → preferred for BullMQ. Railway-native Redis (no command limits) is
# preferred over Upstash for the queue; uses plain redis:// internally.
REDIS_URL=redis://default:your-password@your-railway-redis:6379
# Upstash is the fallback queue connection AND powers REST-based rate limiting.
# Use rediss:// (TLS) in production — get from Upstash Dashboard
UPSTASH_REDIS_URL=rediss://default:your-password@your-db.upstash.io:6379
# REST vars below are used for rate limiting (@upstash/ratelimit), not BullMQ.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# ─── Resend (contact form + admin email campaigns) ────────────────────────────
# Sign up free at https://resend.com — 100 emails/day free
# Verify your domain (flowfiy.com) in Resend dashboard for real bulk delivery
RESEND_API_KEY=re_...
# From address for outbound email — MUST be on a Resend-verified domain to send
# to anyone other than the account owner. Defaults to onboarding@resend.dev (sandbox).
RESEND_FROM_EMAIL=Flowfiy <hello@flowfiy.com>

# ─── Meta Marketing API (Flowfiy ad campaigns) ───────────────────────────────
# 1. Business Manager + Ad Account (with a payment method): https://business.facebook.com
# 2. Meta app w/ Marketing API: https://developers.facebook.com/apps  (type: Business)
# 3. System User (Business Settings > Users > System Users) → generate token with
#    scopes: ads_management, ads_read, business_management — assign the Ad Account + Page to it.
# Put the REAL values in .env.local (gitignored), never commit them.
META_ACCESS_TOKEN=EAAB...            # system-user token (long-lived / never-expiring)
META_AD_ACCOUNT_ID=act_1234567890    # Ad account ID, INCLUDING the act_ prefix
META_PAGE_ID=1234567890              # Facebook Page the ads run from
META_APP_ID=1234567890               # (optional) for appsecret_proof
META_APP_SECRET=your-app-secret      # (optional) for appsecret_proof
META_API_VERSION=v21.0               # Graph API version

# ─── Meta Pixel (browser) ──────────────────────────────────────────────────────
# Pixel id is public (shipped to the browser). Override per env if needed.
NEXT_PUBLIC_META_PIXEL_ID=1625820488509651

# ─── App ──────────────────────────────────────────────────────────────────────
# Development:  http://localhost:3000
# Production:   https://flowfiy.com
NEXT_PUBLIC_APP_URL=https://flowfiy.com
NODE_ENV=production
