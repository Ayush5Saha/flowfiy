{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/billing/webhook/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/leads/generate/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/campaigns/process-followups/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/campaigns/process-followups",
      "schedule": "0 * * * *"
    }
  ]
}
