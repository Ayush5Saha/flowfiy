generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Organizations (Tenants) ─────────────────────────────────────────────────

model Organization {
  id                   String    @id @default(uuid())
  name                 String
  slug                 String    @unique
  plan                 Plan      @default(FREE)
  razorpayCustomerId     String?   @unique @map("razorpay_customer_id")
  razorpaySubscriptionId String?   @unique @map("razorpay_subscription_id")
  stripeCustomerId       String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map("stripe_subscription_id")
  billingGateway         String?   @map("billing_gateway") // "razorpay" | "stripe"
  subscriptionStatus     String?   @map("subscription_status")
  generationCount      Int       @default(0) @map("generation_count")
  generationLimit      Int       @default(100) @map("generation_limit")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  referralCode         String?   @unique @map("referral_code")
  referralCreditMonths Int       @default(0) @map("referral_credit_months")

  monthlyTokensUsed  BigInt    @default(0) @map("monthly_tokens_used")
  tokenBudgetResetAt DateTime? @map("token_budget_reset_at")

  members           OrganizationMember[]
  businessProfile   BusinessProfile?
  integrations      Integration[]
  leadLists         LeadList[]
  campaigns         Campaign[]
  usageEvents       UsageEvent[]
  auditLogs         AuditLog[]
  suppressedEmails  SuppressedEmail[]
  webhookEndpoints  WebhookEndpoint[]
  referralsMade     Referral[] @relation("referrerOrg")
  referredBy        Referral[] @relation("referredOrg")

  @@map("organizations")
}

enum Plan {
  FREE
  STARTER
  GROWTH
  AGENCY
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  role           MemberRole   @default(MEMBER)
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Business Profile (ICP) ───────────────────────────────────────────────────

model BusinessProfile {
  id                  String   @id @default(uuid())
  organizationId      String   @unique @map("organization_id")
  companyName         String   @map("company_name")
  website             String?
  serviceOffered      String   @map("service_offered")
  icpDescription      String   @map("icp_description")
  targetIndustries    String[] @map("target_industries")
  targetGeographies   String[] @map("target_geographies")
  companySizeRange    String?  @map("company_size_range")
  painPointsSolved    String   @map("pain_points_solved")
  offerPositioning    String   @map("offer_positioning")
  outreachTone        String   @default("professional") @map("outreach_tone")
  icpAnalysisCache    Json?    @map("icp_analysis_cache")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model Integration {
  id                   String            @id @default(uuid())
  organizationId       String            @map("organization_id")
  type                 IntegrationType
  encryptedCredentials String            @map("encrypted_credentials")
  status               IntegrationStatus @default(DISCONNECTED)
  lastValidatedAt      DateTime?         @map("last_validated_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@map("integrations")
}

enum IntegrationType {
  CLAUDE
  APOLLO
  APIFY
  GMAIL
  CALENDLY
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

// ─── Lead Lists ───────────────────────────────────────────────────────────────

model LeadList {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  name            String
  description     String?
  status          LeadListStatus @default(DRAFT)
  totalLeads      Int            @default(0) @map("total_leads")
  qualifiedLeads  Int            @default(0) @map("qualified_leads")
  jobId           String?        @map("job_id")
  jobStatus       String?        @map("job_status")
  jobError        String?        @map("job_error")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]
  campaigns    Campaign[]

  @@map("lead_lists")
}

enum LeadListStatus {
  DRAFT
  QUEUED
  RESEARCHING
  READY
  ARCHIVED
  FAILED
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id                String     @id @default(uuid())
  leadListId        String     @map("lead_list_id")
  organizationId    String     @map("organization_id")
  firstName         String?    @map("first_name")
  lastName          String?    @map("last_name")
  email             String?
  title             String?
  companyName       String?    @map("company_name")
  companyWebsite    String?    @map("company_website")
  companySize       String?    @map("company_size")
  industry          String?
  linkedinUrl       String?    @map("linkedin_url")
  source            String?
  rawData           Json?      @map("raw_data")
  status            LeadStatus @default(NEW)
  qualificationScore Int?      @map("qualification_score")
  timezone          String?    // IANA timezone e.g. "Asia/Kolkata", "America/New_York"
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  leadList       LeadList       @relation(fields: [leadListId], references: [id], onDelete: Cascade)
  research       LeadResearch?
  outreachCopies OutreachCopy[]
  campaignLeads  CampaignLead[]

  @@map("leads")
}

enum LeadStatus {
  NEW
  RESEARCHING
  QUALIFIED
  DISQUALIFIED
  CONTACTED
  REPLIED
  MEETING_BOOKED
}

// ─── Lead Research ────────────────────────────────────────────────────────────

model LeadResearch {
  id                   String   @id @default(uuid())
  leadId               String   @unique @map("lead_id")
  organizationId       String   @map("organization_id")
  companyAnalysis      Json?    @map("company_analysis")
  opportunityAngle     String?  @map("opportunity_angle")
  painPointMatch       String?  @map("pain_point_match")
  personalizationNotes String?  @map("personalization_notes")
  researchMetadata     Json?    @map("research_metadata")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_research")
}

// ─── Outreach Copy ────────────────────────────────────────────────────────────

model OutreachCopy {
  id           String   @id @default(uuid())
  leadId       String   @map("lead_id")
  organizationId String  @map("organization_id")
  channel      String   @default("email")
  subjectLine  String?  @map("subject_line")
  body         String
  followUp1    String?  @map("follow_up_1")
  followUp2    String?  @map("follow_up_2")
  followUp3    String?  @map("follow_up_3")
  variant      String   @default("A") // A/B test variant
  version      Int      @default(1)
  isApproved   Boolean  @default(false) @map("is_approved")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignLeads CampaignLead[]

  @@map("outreach_copies")
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id                  String         @id @default(uuid())
  organizationId      String         @map("organization_id")
  leadListId          String?        @map("lead_list_id")
  name                String
  status              CampaignStatus @default(DRAFT)
  channel             String         @default("email")
  gmailFromAddress    String?        @map("gmail_from_address")
  calendlyLink        String?        @map("calendly_link")
  dailySendLimit      Int            @default(50) @map("daily_send_limit")
  followUp1DelayDays  Int            @default(3)  @map("follow_up1_delay_days")
  followUp2DelayDays  Int            @default(7)  @map("follow_up2_delay_days")
  followUp3DelayDays  Int            @default(14) @map("follow_up3_delay_days")
  abTestEnabled       Boolean        @default(false) @map("ab_test_enabled")
  sentCount           Int            @default(0) @map("sent_count")
  replyCount          Int            @default(0) @map("reply_count")
  meetingCount        Int            @default(0) @map("meeting_count")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadList      LeadList?      @relation(fields: [leadListId], references: [id])
  campaignLeads CampaignLead[]

  @@map("campaigns")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model CampaignLead {
  id                String         @id @default(uuid())
  campaignId        String         @map("campaign_id")
  leadId            String         @map("lead_id")
  outreachCopyId    String?        @map("outreach_copy_id")
  status            OutreachStatus @default(PENDING)
  followUpStep      Int            @default(0)  @map("follow_up_step")
  sentAt            DateTime?      @map("sent_at")
  followUp1SentAt   DateTime?      @map("follow_up1_sent_at")
  followUp2SentAt   DateTime?      @map("follow_up2_sent_at")
  followUp3SentAt   DateTime?      @map("follow_up3_sent_at")
  gmailMessageId    String?        @map("gmail_message_id")
  gmailThreadId     String?        @map("gmail_thread_id")
  openedAt          DateTime?      @map("opened_at")
  openCount         Int            @default(0) @map("open_count")
  replyIntent       String?        @map("reply_intent") // INTERESTED | NOT_INTERESTED | OOO | REFERRAL | UNSUBSCRIBE | OTHER
  replySnippet      String?        @map("reply_snippet") // first 300 chars of reply for display
  bounceReason      String?        @map("bounce_reason") // HARD | SOFT | SPAM — set on Gmail send failure
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  campaign      Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead          Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  outreachCopy  OutreachCopy? @relation(fields: [outreachCopyId], references: [id])

  @@unique([campaignId, leadId])
  @@map("campaign_leads")
}

enum OutreachStatus {
  PENDING
  SENT
  OPENED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

// ─── Usage & Billing ──────────────────────────────────────────────────────────

model UsageEvent {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  eventType      String   @map("event_type")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("usage_events")
}

// ─── Prompt Templates ─────────────────────────────────────────────────────────

model PromptTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  version   Int      @default(1)
  content   String
  variables Json?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("prompt_templates")
}

// ─── Email Suppression ────────────────────────────────────────────────────────

/**
 * Org-scoped list of email addresses that must never receive outreach.
 * Populated automatically on unsubscribe or bounce; can also be added manually.
 */
model SuppressedEmail {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  email          String
  reason         String   @default("unsubscribed") // unsubscribed | bounced | manual
  suppressedAt   DateTime @default(now()) @map("suppressed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@map("suppressed_emails")
}

// ─── Webhook Endpoints ───────────────────────────────────────────────────────

/**
 * Outgoing webhooks — Flowfiy fires a signed POST to these URLs on key events:
 *   lead.qualified, reply.received, campaign.completed, meeting.booked
 * Payload is signed with HMAC-SHA256 using the endpoint's secret.
 */
model WebhookEndpoint {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  url             String
  secret          String   // random 32-byte hex, shown once at creation
  events          String[] // e.g. ["lead.qualified", "reply.received"]
  isActive        Boolean  @default(true) @map("is_active")
  lastDeliveredAt DateTime? @map("last_delivered_at")
  failureCount    Int      @default(0) @map("failure_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("webhook_endpoints")
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id              String    @id @default(uuid())
  referrerOrgId   String    @map("referrer_org_id")
  referredOrgId   String    @map("referred_org_id")
  referredPlan    Plan      @map("referred_plan")
  rewardApplied   Boolean   @default(false) @map("reward_applied")
  rewardAppliedAt DateTime? @map("reward_applied_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  referrerOrg Organization @relation("referrerOrg", fields: [referrerOrgId], references: [id])
  referredOrg Organization @relation("referredOrg", fields: [referredOrgId], references: [id])

  @@unique([referrerOrgId, referredOrgId])
  @@map("referrals")
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  action         String
  resourceType   String?  @map("resource_type")
  resourceId     String?  @map("resource_id")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
